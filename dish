#!/bin/bash

set -uo pipefail

OPTION_CLR=$'\033[38;5;12m'
ERROR_CLR=$'\033[38;5;196m'
SUCCESS_CLR=$'\033[38;5;40m'
WARN_CLR=$'\033[38;5;214m'
DIM_CLR=$'\033[38;5;245m'
RESET=$'\033[0m'

cmdname=$(basename "$0")

# Cached OS family — set once in main() via check_os, reused everywhere
OS=""

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

vlog() { [[ "$do_verbose" -eq 1 ]] && echo -e "${DIM_CLR}[verbose]${RESET} $*"; }

# Top-level helper: check whether $1 contains substring $2
contains() { [[ "$1" == *"$2"* ]]; }

usage() {
    echo -e "Usage: $cmdname [${OPTION_CLR}options...${RESET}]"
    echo -e "    ${OPTION_CLR}-h${RESET}, ${OPTION_CLR}--help${RESET}        │ show this help message                           │"
    echo -e "    ${OPTION_CLR}-i${RESET}, ${OPTION_CLR}--install${RESET}     │ install discord file accordingly to linux family │"
    echo -e "    ${OPTION_CLR}-u${RESET}, ${OPTION_CLR}--update${RESET}      │ update discord accordingly to linux family       │"
    echo -e "    ${OPTION_CLR}-v${RESET}, ${OPTION_CLR}--vencord${RESET}     │ launch Vencord CLI                               │"
    echo -e "    ${OPTION_CLR}-d${RESET}, ${OPTION_CLR}--delete${RESET}      │ uninstall/delete discord from system             │"
    echo -e "    ${OPTION_CLR}-V${RESET}, ${OPTION_CLR}--verbose${RESET}     │ make the operation more talkative                │"
}

error() {
    echo -e "${ERROR_CLR}Invalid option.${RESET} Use ${OPTION_CLR}-h${RESET} or ${OPTION_CLR}--help${RESET} for usage information."
}

no_arg() {
    echo -e "${ERROR_CLR}No options provided.${RESET} Use ${OPTION_CLR}-h${RESET} or ${OPTION_CLR}--help${RESET} for usage information."
}

# ---------------------------------------------------------------------------
# Dependency check
# ---------------------------------------------------------------------------

check_deps() {
    vlog "Checking required dependencies..."
    local missing=()
    for dep in wget sudo; do
        if ! command -v "$dep" &>/dev/null; then
            missing+=("$dep")
        else
            vlog "  ✔ $dep found at $(command -v "$dep")"
        fi
    done

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo -e "${ERROR_CLR}Missing required dependencies:${RESET} ${missing[*]}"
        echo "Please install them and try again."
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# OS detection — run once in main(), result cached in $OS
# ---------------------------------------------------------------------------

check_os() {
    local id="" id_like="" source_file=""

    if [[ -f /etc/os-release ]]; then
        source_file="/etc/os-release"
    elif [[ -f /usr/lib/os-release ]]; then
        source_file="/usr/lib/os-release"
    else
        echo -e "${ERROR_CLR}Could not find /etc/os-release or /usr/lib/os-release.${RESET}" >&2
        echo "Your distribution may not be supported." >&2
        exit 1
    fi

    # Pre-declare optional fields so set -u doesn't abort if the file omits them
    # (ID_LIKE is not required by the os-release spec)
    ID_LIKE=""

    # shellcheck source=/dev/null
    source "$source_file"
    id="${ID,,}"
    id_like="${ID_LIKE,,}"
    vlog "OS detection: sourced $source_file"
    vlog "OS detection: ID='$id'  ID_LIKE='$id_like'"

    for field in "$id_like" "$id"; do
        { contains "$field" "debian" || contains "$field" "ubuntu"; } && { vlog "Detected: Debian-based"; echo "Debian-based"; return; }
        { contains "$field" "rhel" || contains "$field" "fedora" || contains "$field" "centos"; } && { vlog "Detected: Red Hat-based"; echo "Red Hat-based"; return; }
        { contains "$field" "arch" || contains "$field" "archlinux"; } && { vlog "Detected: Arch-based"; echo "Arch-based"; return; }
        { contains "$field" "suse" || contains "$field" "opensuse"; } && { vlog "Detected: SUSE-based"; echo "SUSE-based"; return; }
        contains "$field" "gentoo" && { vlog "Detected: Gentoo-based"; echo "Gentoo-based"; return; }
        contains "$field" "slackware" && { vlog "Detected: Slackware-based"; echo "Slackware-based"; return; }
    done

    echo -e "${ERROR_CLR}Unsupported Linux distribution (ID='$id').${RESET}" >&2
    exit 1
}

# ---------------------------------------------------------------------------
# Version helpers
# ---------------------------------------------------------------------------

get_installed_version() {
    if [[ "$OS" == "Debian-based" ]]; then
        vlog "Reading installed version via dpkg..."
        # dpkg returns non-zero if the package is absent — treat that as empty
        dpkg -s discord 2>/dev/null | grep '^Version:' | awk '{print $2}' || true
    else
        local build_info="/opt/Discord/resources/build_info.json"
        vlog "Reading installed version from $build_info..."
        if [[ -f "$build_info" ]]; then
            grep -o '"version":"[^"]*"' "$build_info" | cut -d'"' -f4 || true
        fi
    fi
}

get_latest_version() {
    local api_url="https://discord.com/api/updates/stable?platform=linux"
    vlog "Fetching latest version from $api_url..."
    wget -qO- "$api_url" | grep -o '"name":"[^"]*"' | cut -d'"' -f4
}

# ---------------------------------------------------------------------------
# Install
# ---------------------------------------------------------------------------

install_discord() {
    # When called from update_discord, skip the already-installed guard
    local skip_installed_check="${1:-false}"

    if [[ "$skip_installed_check" != "true" ]]; then
        local existing
        existing=$(get_installed_version)
        if [[ -n "$existing" ]]; then
            echo -e "${WARN_CLR}Discord $existing is already installed.${RESET}"
            read -rp "Reinstall anyway? [y/N] " confirm_reinstall
            [[ "${confirm_reinstall,,}" != "y" && "${confirm_reinstall,,}" != "yes" ]] && echo "Aborted." && return
        fi
    fi

    local url format
    if [[ "$OS" == "Debian-based" ]]; then
        format="deb"
        url="https://discord.com/api/download?platform=linux&format=deb"
    else
        format="tar.gz"
        url="https://discord.com/api/download?platform=linux&format=tar.gz"
    fi

    local dest="/tmp/discord.$format"
    echo "Downloading Discord ($format)..."
    vlog "URL    : $url"
    vlog "Dest   : $dest"
    vlog "Distro : $OS"

    local wget_flags=()
    [[ "$do_verbose" -eq 0 ]] && wget_flags+=("-q")

    if ! wget "${wget_flags[@]}" "$url" -O "$dest"; then
        echo -e "${ERROR_CLR}Download failed.${RESET} Check your internet connection."
        rm -f "$dest"
        exit 1
    fi

    vlog "Download complete. Installing..."

    if [[ "$OS" == "Debian-based" ]]; then
        vlog "Running: sudo dpkg -i $dest"
        if [[ "$do_verbose" -eq 1 ]]; then
            sudo dpkg -i "$dest"
        else
            sudo dpkg -i "$dest" > /dev/null
        fi
    else
        vlog "Extracting $dest to /opt/"
        if [[ "$do_verbose" -eq 1 ]]; then
            tar -xzvf "$dest" -C /opt/
        else
            tar -xzf "$dest" -C /opt/ > /dev/null
        fi
        vlog "Creating symlink: /usr/bin/discord → /opt/Discord/Discord"
        sudo ln -sf /opt/Discord/Discord /usr/bin/discord
    fi

    vlog "Cleaning up $dest"
    rm -f "$dest"
    echo -e "${SUCCESS_CLR}Discord installed successfully.${RESET}"
}

# ---------------------------------------------------------------------------
# Update
# ---------------------------------------------------------------------------

update_discord() {
    echo "Checking for Discord updates..."

    local installed
    installed=$(get_installed_version)

    if [[ -z "$installed" ]]; then
        echo -e "${ERROR_CLR}Discord does not appear to be installed.${RESET} Use ${OPTION_CLR}-i${RESET} to install it first."
        exit 1
    fi

    local latest
    latest=$(get_latest_version)

    if [[ -z "$latest" ]]; then
        echo -e "${ERROR_CLR}Could not reach Discord update API. Check your internet connection.${RESET}"
        exit 1
    fi

    vlog "Installed version : $installed"
    vlog "Latest version : $latest"

    if [[ "$installed" == "$latest" ]]; then
        echo -e "${SUCCESS_CLR}Discord is already up to date${RESET} (${installed})."
        return
    fi

    echo -e "${WARN_CLR}Update available:${RESET} $installed → $latest"
    # Skip the already-installed guard and suppress the generic "installed" message
    install_discord true
    # Replace install_discord's success line with a more specific update message
    echo -e "${SUCCESS_CLR}Discord updated successfully:${RESET} $installed → $latest"
}

# ---------------------------------------------------------------------------
# Vencord
# ---------------------------------------------------------------------------

launch_vencord() {
    local vencord_bin="$HOME/.local/bin/VencordInstallerCli"
    local vencord_url="https://github.com/Vencord/Installer/releases/latest/download/VencordInstallerCli-linux"

    mkdir -p "$HOME/.local/bin"

    if [[ ! -f "$vencord_bin" ]]; then
        echo "VencordInstallerCli not found. Downloading..."
        vlog "URL  : $vencord_url"
        vlog "Dest : $vencord_bin"

        local wget_flags=()
        [[ "$do_verbose" -eq 0 ]] && wget_flags+=("-q")

        if ! wget "${wget_flags[@]}" "$vencord_url" -O "$vencord_bin"; then
            echo -e "${ERROR_CLR}Failed to download VencordInstallerCli.${RESET}"
            rm -f "$vencord_bin"
            exit 1
        fi

        chmod +x "$vencord_bin"
        vlog "Marked $vencord_bin as executable"
        echo -e "${SUCCESS_CLR}VencordInstallerCli downloaded.${RESET}"
    else
        vlog "VencordInstallerCli already present at $vencord_bin — skipping download"
    fi

    vlog "Launching: sudo $vencord_bin"
    sudo "$vencord_bin"
}

# ---------------------------------------------------------------------------
# Delete
# ---------------------------------------------------------------------------

delete_discord() {
    echo -e "${WARN_CLR}This will remove Discord and its symlink from your system.${RESET}"
    read -rp "Are you sure you want to uninstall Discord? [y/N] " confirm_delete
    if [[ "${confirm_delete,,}" != "y" && "${confirm_delete,,}" != "yes" ]]; then
        echo "Aborted."
        return
    fi

    read -rp "Also delete user config and data (~/.config/discord)? [y/N] " confirm_config

    # Remove binary / package
    if [[ "$OS" == "Debian-based" ]]; then
        # --purge removes package config files too, unlike -r
        vlog "Running: sudo dpkg --purge discord"
        if [[ "$do_verbose" -eq 1 ]]; then
            sudo dpkg --purge discord
        else
            sudo dpkg --purge discord > /dev/null
        fi
    else
        vlog "Removing /opt/Discord"
        sudo rm -rf /opt/Discord
    fi

    # Remove symlink
    if [[ -L /usr/bin/discord ]]; then
        vlog "Removing symlink /usr/bin/discord"
        sudo rm -f /usr/bin/discord
        echo "Removed symlink /usr/bin/discord."
    else
        vlog "No symlink found at /usr/bin/discord — skipping"
    fi

    # Remove any leftover /tmp files
    vlog "Cleaning up any leftover /tmp/discord.* files"
    rm -f /tmp/discord.deb /tmp/discord.tar.gz

    # Optionally remove user config
    if [[ "${confirm_config,,}" == "y" || "${confirm_config,,}" == "yes" ]]; then
        if [[ -d "$HOME/.config/discord" ]]; then
            vlog "Removing $HOME/.config/discord"
            rm -rf "$HOME/.config/discord"
            echo "Removed ~/.config/discord."
        else
            vlog "~/.config/discord not found — nothing to remove"
        fi
    fi

    echo -e "${SUCCESS_CLR}Discord has been uninstalled.${RESET}"
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

main() {

    if [ $# -eq 0 ]; then
        no_arg
        exit 0
    fi

    params="$(getopt --options hiuvdV \
                     --longoptions help,verbose,install,update,vencord,delete \
                     --name "$cmdname" -- "$@")"

    if [ $? -ne 0 ]; then
        error
        exit 1
    fi

    eval set -- "$params"
    unset params

    do_verbose=0
    do_install=0
    do_update=0
    do_vencord=0
    do_delete=0

    while true; do
        case $1 in
            -h|--help) usage; exit 0 ;;
            -V|--verbose) do_verbose=1; shift ;;
            -i|--install) do_install=1; shift ;;
            -u|--update) do_update=1; shift ;;
            -v|--vencord) do_vencord=1; shift ;;
            -d|--delete) do_delete=1; shift ;;
            --) shift; break ;;
            *) error; exit 1 ;;
        esac
    done

    # Mutual exclusion: --install and --update together make no sense
    if [[ $do_install -eq 1 && $do_update -eq 1 ]]; then
        echo -e "${ERROR_CLR}--install and --update are mutually exclusive.${RESET} Use one at a time."
        exit 1
    fi

    check_deps

    # Detect OS once and cache globally — all functions use $OS directly
    OS=$(check_os)
    vlog "OS family: $OS"

    [ $do_install -eq 1 ] && install_discord
    [ $do_update  -eq 1 ] && update_discord
    [ $do_delete  -eq 1 ] && delete_discord
    [ $do_vencord -eq 1 ] && launch_vencord
}

main "$@"
